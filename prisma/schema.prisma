generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // For Neon: use pooled in DATABASE_URL + direct (non-pooled) in DIRECT_URL for migrations
}

// ─── PII PLAINTEXT MIGRATION PLAN (audit S2) ─────────────────────────────────
// Phase 2 [BACKFILL COMPLETE]: *Encrypted columns are canonical for reads; S2 backfill done.
// ACTIVE dual-storage writes remain for RepairOrder.roNumber and RepairLine.description
// (see src/lib/roMapper.ts repairOrderToDbFields / repairLineToDbFields). Plaintext
// columns are still written at create/update until Phase 4 write cutover.
//
// ── Dual-storage fields (plaintext + encrypted both written until Phase 4) ────
// RepairOrder.roNumber
//   → roNumberEncrypted (canonical for decrypt-first reads)
//   WRITE: src/lib/roMapper.ts — roNumber and roNumberEncrypted both written
//   READ:  src/lib/roMapper.ts dbToRepairOrder (decrypt first, plaintext fallback)
//   SEARCH: src/lib/roListQuery.ts buildRepairOrderListWhere (contains on roNumber)
//   CLIENT: src/hooks/repairOrders/roListUtils.ts matchesROSearch (in-memory filter)
//
// RepairLine.description
//   → descriptionEncrypted (canonical for decrypt-first reads)
//   WRITE: src/lib/roMapper.ts — description and descriptionEncrypted both written
//   READ:  src/lib/roMapper.ts dbToRepairLine (decrypt first, plaintext fallback)
//
// RepairOrder.serviceAdvisorName (denormalized, encrypted-only at rest)
//   → serviceAdvisorNameEncrypted
//   READ/WRITE: src/lib/roMapper.ts
//
// ServiceAdvisor.displayName
//   → displayNameEncrypted (canonical, backfill complete)
//   READ:  src/app/api/advisors/*.ts, dbToRepairOrder serviceAdvisor join
//
// ── Plaintext-only fields (no encrypted twin yet — future schema work) ────────
// ServiceAdvisorAlias.aliasText          — advisor alias strings (fingerprint used for match)
// AdvisorWritingProfile.profileData      — JSON writing-style samples (may contain complaint text)
// Technician.name / email              — auth identity (separate from RO PII scope)
// AuditLog.metadata.roNumber             — operational identifier in hash-chain audit (not customer PII)
// Template.title / description           — non-customer template catalog metadata
//
// Already encrypted-only at rest (no S2 dual-storage gap):
//   customerNameEncrypted, complaintsEncrypted, vinEncrypted, customerConcernEncrypted,
//   technicianNotesEncrypted, warrantyStoryEncrypted, xentryOcrTextsEncrypted,
//   extractedDataEncrypted, complaintTextEncrypted, contentEncrypted, knowledge base *Encrypted
//
// ── Phased cutover (non-breaking) ─────────────────────────────────────────────
// Phase 1 [COMPLETE] — dual-write introduced encrypted twins for RO/advisor fields
//
// Phase 2 [BACKFILL COMPLETE] — backfill finished; dual-storage writes still active
//   • npm run db:migrate-pii-safe / db:migrate-pii / db:reencrypt completed
//   • *Encrypted columns are canonical for reads; roNumber/description still dual-written
//
// Phase 3 [CURRENT — requires search replacement]
//   • dbToRepairOrder / dbToRepairLine: encrypted-only reads (remove plaintext fallback)
//   • dbToRepairOrder: decrypt ServiceAdvisor.displayNameEncrypted on join
//   • Add RepairOrder.roNumberSearchToken (HMAC blind index) for list/search queries
//   • roListQuery + roListUtils: query token instead of plaintext roNumber
//
// Phase 4 [WRITE CUTOVER]
//   • resolveAdvisor.ts: write displayNameEncrypted alongside displayName
//   • roMapper: stop writing RepairOrder.roNumber and RepairLine.description plaintext
//   • Dashboard/advisor APIs: read from encrypted columns only
//
// Phase 5 [SCHEMA CLEANUP — one release after Phase 4]
//   • Drop plaintext columns: roNumber, description, displayName (Prisma migration)
//   • Add encrypted columns for aliasText / profileData if still needed
//   • Final npm run db:migrate-pii + db:reencrypt on restored backups only
//
// Rollback: restore pre-migration database backup. Do not rotate ENCRYPTION_KEY without
// a planned key-migration procedure. See docs/Reencryption-Runbook.md.

/** M11: enforce technician/manager at the database layer. */
enum TechnicianRole {
  technician
  manager
  service_advisor
}

model Dealership {
  id              String                        @id @default(cuid())
  name            String
  createdAt       DateTime                      @default(now())
  technicians     Technician[]
  repairOrders    RepairOrder[]
  auditLogs       AuditLog[]
  usageLogs       UsageLog[]
  serviceAdvisors ServiceAdvisor[]
  advisorObservations AdvisorComplaintObservation[]
}

model Technician {
  id             String        @id @default(cuid())
  email          String        @unique
  d7Number       String        @unique
  name           String
  passwordHash   String
  role           TechnicianRole @default(technician)
  isAdmin        Boolean       @default(false)
  isActive       Boolean       @default(true)
  sessionVersion Int           @default(0)
  dealershipId   String
  dealership     Dealership    @relation(fields: [dealershipId], references: [id])
  /** Links service_advisor role logins to their ServiceAdvisor profile for RO scoping. */
  serviceAdvisorId String?
  serviceAdvisor   ServiceAdvisor? @relation(fields: [serviceAdvisorId], references: [id], onDelete: SetNull)
  consentAt      DateTime?
  consentVersion String?
  legalDisclaimerAt      DateTime?
  legalDisclaimerVersion String?
  firstAppLaunchAt       DateTime?
  firstAppLaunchSessionId String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  repairOrders         RepairOrder[]
  auditLogs            AuditLog[]
  usageLogs            UsageLog[]
  technicianActivityLogs TechnicianActivityLog[]
  certifiedStories       TechnicianCertifiedStory[]

  @@index([dealershipId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([serviceAdvisorId])
}

model RepairOrder {
  id                         String       @id @default(cuid())
  /** S2 legacy: read-only for list/search until Phase 5 drop. Canonical: roNumberEncrypted (Phase 2 complete). */
  roNumber                   String
  /** M7: encrypted RO number — canonical value at rest (Phase 2 backfill complete). */
  roNumberEncrypted          String       @default("")
  technicianId               String
  technician                 Technician   @relation(fields: [technicianId], references: [id])
  dealershipId               String
  dealership                 Dealership   @relation(fields: [dealershipId], references: [id])
  serviceAdvisorId           String?
  serviceAdvisor             ServiceAdvisor? @relation(fields: [serviceAdvisorId], references: [id], onDelete: SetNull)
  serviceAdvisorNameEncrypted String      @default("")
  advisorMatchConfidence     Float?
  advisorIdentifiedAt        DateTime?
  vinEncrypted               String       @default("")
  year                       String       @default("")
  make                       String       @default("")
  model                      String       @default("")
  engine                     String       @default("")
  mileageIn                  String       @default("")
  mileageOut                 String       @default("")
  customerNameEncrypted      String       @default("")
  complaintsEncrypted        String       @default("[]")
  xentryOcrTextsEncrypted    String       @default("")
  xentryImageUrls            String       @default("[]")
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  repairLines                RepairLine[]
  advisorObservations        AdvisorComplaintObservation[]

  @@index([technicianId])
  @@index([dealershipId])
  @@index([roNumber])
  @@index([serviceAdvisorId])
}

// ─── Advisor Intelligence (Phase 1) ─────────────────────────────────────────

model ServiceAdvisor {
  id              String   @id @default(cuid())
  dealershipId    String
  dealership      Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  /** S2 legacy: read-only for UI until Phase 5 drop. Canonical: displayNameEncrypted (Phase 2 complete). */
  displayName     String
  /** M7: encrypted advisor display name — canonical at rest (Phase 2 backfill complete). */
  displayNameEncrypted String @default("")
  nameFingerprint String
  advisorCode     String?
  status          String   @default("active")
  mergedIntoId    String?
  /** Soft delete — historical ROs, observations, and audit data are preserved. */
  deletedAt       DateTime?
  /** Optional dealership CSI score when survey data is available. */
  csiScore        Float?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  roCount         Int      @default(0)
  aliases         ServiceAdvisorAlias[]
  observations    AdvisorComplaintObservation[]
  profile         AdvisorWritingProfile?
  repairOrders    RepairOrder[]
  linkedAccounts  Technician[]

  @@unique([dealershipId, nameFingerprint])
  @@index([dealershipId, lastSeenAt])
  @@index([dealershipId, status])
  @@index([dealershipId, deletedAt])
}

model ServiceAdvisorAlias {
  id               String         @id @default(cuid())
  serviceAdvisorId String
  serviceAdvisor   ServiceAdvisor @relation(fields: [serviceAdvisorId], references: [id], onDelete: Cascade)
  aliasText        String
  aliasFingerprint String
  hitCount         Int            @default(1)
  lastSeenAt       DateTime       @default(now())

  @@unique([serviceAdvisorId, aliasFingerprint])
  @@index([aliasFingerprint])
}

model AdvisorComplaintObservation {
  id                     String         @id @default(cuid())
  dealershipId           String
  dealership             Dealership     @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  serviceAdvisorId       String
  serviceAdvisor         ServiceAdvisor @relation(fields: [serviceAdvisorId], references: [id], onDelete: Cascade)
  repairOrderId          String
  repairOrder            RepairOrder    @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineLabel              String?
  complaintTextEncrypted String
  extractionSource       String
  extractionConfidence   Float?
  wasCorrected           Boolean        @default(false)
  vehicleMake            String?
  vehicleModel           String?
  vehicleFamily          String?
  observedAt             DateTime       @default(now())

  @@index([serviceAdvisorId, observedAt])
  @@index([repairOrderId])
  @@index([dealershipId, observedAt])
}

model AdvisorWritingProfile {
  id               String         @id @default(cuid())
  serviceAdvisorId String         @unique
  serviceAdvisor   ServiceAdvisor @relation(fields: [serviceAdvisorId], references: [id], onDelete: Cascade)
  profileVersion   Int            @default(1)
  /** S2: advisor profile JSON may contain writing-style samples — encrypt or redact in Phase 3. */
  profileData      String         @default("{}")
  observationCount Int            @default(0)
  lastComputedAt   DateTime?
  updatedAt        DateTime       @updatedAt
}

model RepairLine {
  id                        String      @id @default(cuid())
  repairOrderId             String
  repairOrder               RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineNumber                Int
  /** S2 legacy: read-only fallback until Phase 5 drop. Canonical: descriptionEncrypted (Phase 2 complete). */
  description               String
  /** M7: encrypted line description — canonical at rest (Phase 2 backfill complete). */
  descriptionEncrypted      String      @default("")
  customerConcernEncrypted  String      @default("")
  technicianNotesEncrypted  String      @default("")
  xentryImageUrls           String      @default("[]")
  xentryOcrTextsEncrypted   String      @default("")
  extractedDataEncrypted    String      @default("{}")
  warrantyStoryEncrypted    String?
  /** Encrypted JSON: last MI audit/review score + coaching payload for this line. */
  storyQualityAuditEncrypted String     @default("")
  /** True when story came from a Customer Pay template — skips AI generation and quality audit. */
  isCustomerPay             Boolean     @default(false)
  /** Advisor-captured sold metrics — used for dealership KPI dashboards. */
  soldLaborHours            Float?
  soldLaborAmount           Float?
  soldPartsAmount           Float?
  customerApproved          Boolean?
  isAddOn                   Boolean?
  soldMetricsUpdatedAt      DateTime?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  @@index([repairOrderId])
}

model Template {
  id           String    @id @default(cuid())
  title        String
  category     String
  contentEncrypted String @db.Text
  /** Customer Pay templates bypass Merlin AI — instant pre-written stories. */
  isCustomerPay Boolean  @default(false)
  templateType  String   @default("Warranty")
  description   String?
  source       String    @default("seed")
  dealershipId String    @default("__global__")
  createdById  String?
  useCount     Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([dealershipId, title])
  @@index([category])
  @@index([dealershipId, lastUsedAt])
  @@index([source])
}

model KnowledgeBase {
  id               String   @id @default(cuid())
  title            String
  category         String
  generatedTextEncrypted    String? @db.Text
  fullOriginalTextEncrypted String  @db.Text
  cleanTemplateEncrypted    String  @db.Text
  tags             String   @default("[]")
  source           String   @default("seed")
  dealershipId     String   @default("__global__")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([dealershipId, title])
  @@index([category])
  @@index([dealershipId])
  @@index([source])
}

model AuditLog {
  id           String      @id @default(cuid())
  action       String
  entityType   String?
  entityId     String?
  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id])
  metadata       String      @default("{}")
  ipAddress      String?
  /** Merlin prompt version for AI story events; legacy for pre-migration rows; n/a for non-AI actions. */
  promptVersion  String      @default("legacy")
  previousHash   String      @default("GENESIS")
  entryHash      String      @default("")
  createdAt      DateTime    @default(now())

  @@index([dealershipId])
  @@index([technicianId])
  @@index([action])
  @@index([createdAt])
  @@index([dealershipId, createdAt])
}

/** Operational technician activity — isolated from compliance AuditLog and advisor intelligence. */
/** Certified warranty story indexed per technician — separate from audit/advisor data. */
model TechnicianCertifiedStory {
  id              String     @id @default(cuid())
  dealershipId    String
  technicianId    String
  technician      Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  repairOrderId   String
  repairLineId    String
  roNumber        String
  lineNumber      Int
  certifiedAt     DateTime
  certifiedByName String
  promptVersion   String     @default("legacy")
  auditLogId      String?
  createdAt       DateTime   @default(now())

  @@index([technicianId, certifiedAt(sort: Desc)])
  @@index([dealershipId, certifiedAt(sort: Desc)])
  @@index([repairOrderId])
  @@index([repairLineId])
}

model TechnicianActivityLog {
  id              String   @id @default(cuid())
  dealershipId    String
  technicianId    String
  technician      Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  category        String
  event           String
  message         String
  repairOrderId   String?
  repairLineId    String?
  clientSessionId String?
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())

  @@index([technicianId, createdAt])
  @@index([dealershipId, category, createdAt])
  @@index([repairLineId, createdAt])
  @@index([clientSessionId, createdAt])
}

model UsageLog {
  id           String      @id @default(cuid())
  technicianId String
  technician   Technician  @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  routeKey     String
  createdAt    DateTime    @default(now())

  @@index([technicianId, createdAt])
  @@index([dealershipId, createdAt])
}