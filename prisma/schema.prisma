generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // MERLINUS SINGLE-DEALER: Neon/Prisma Postgres via DATABASE_URL (+ DIRECT_URL for migrations).
  // APEX NATIONAL PLATFORM (Phase 1.5): Supabase pooler on DATABASE_URL, DIRECT_URL for migrations.
  // Set SUPABASE_DATABASE_URL or SUPABASE_DB_PASSWORD — resolved in src/lib/apex/databaseConfig.ts.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── PII ENCRYPTION AT REST (Merlinus v2.0 — Phase 5 complete) ───────────────
// Dual-storage plaintext columns (roNumber, description, displayName) were dropped
// in migration 20250630140000_drop_pii_plaintext_columns. Encrypted columns are the
// sole source of truth for reads and writes.
//
// RepairOrder.roNumberEncrypted + roNumberSearchTokens (blind-index search)
// RepairLine.descriptionEncrypted
// ServiceAdvisor.displayNameEncrypted
// RepairOrder.serviceAdvisorNameEncrypted
//
// ── Plaintext-only fields (future encryption candidates) ──────────────────────
// ServiceAdvisorAlias.aliasText
// AdvisorWritingProfile.profileData
// Technician.name / email (auth identity)
// TechnicianCertifiedStory.roNumber (operational denormalized index, not customer PII)
// AuditLog.metadata.roNumber (hash-chain operational identifier)
// Template.title / description (non-customer catalog metadata)
//
// Rollback: restore pre-Phase-5 database backup. Do not rotate ENCRYPTION_KEY without
// a planned key-migration procedure. See docs/Reencryption-Runbook.md.

/** M11: enforce technician/manager/owner at the database layer. */
enum TechnicianRole {
  technician
  manager
  service_advisor
  /** APEX NATIONAL PLATFORM — national operators; least-privilege, audited dealership context. */
  owner
}

// APEX NATIONAL PLATFORM — top-level franchise tenant for multi-dealer deployments.
// MERLINUS SINGLE-DEALER: one default Dealer row backs the existing Tiverton dealership.
model Dealer {
  id                        String                        @id @default(cuid())
  code                      String                        @unique
  name                      String
  status                    String                        @default("active")
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  dealerships               Dealership[]
  technicians               Technician[]
  repairOrders              RepairOrder[]
  repairLines               RepairLine[]
  auditLogs                 AuditLog[]
  usageLogs                 UsageLog[]
  serviceAdvisors           ServiceAdvisor[]
  advisorObservations       AdvisorComplaintObservation[]
  certifiedStories          TechnicianCertifiedStory[]
  technicianActivityLogs    TechnicianActivityLog[]
  templates                 Template[]
  knowledgeBaseEntries      KnowledgeBase[]

  @@index([status])
  @@map("Dealer")
}

// MERLINUS SINGLE-DEALER — physical store / rooftop (unchanged concept; now optionally under Dealer).
model Dealership {
  id              String                        @id @default(cuid())
  name            String
  dealerId        String?                       @map("dealer_id")
  dealer          Dealer?                       @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  createdAt       DateTime                      @default(now())
  technicians     Technician[]
  repairOrders    RepairOrder[]
  auditLogs       AuditLog[]
  usageLogs       UsageLog[]
  serviceAdvisors ServiceAdvisor[]
  advisorObservations AdvisorComplaintObservation[]
  technicianMemberships TechnicianDealership[]

  @@index([dealerId])
}

// MERLINUS SINGLE-DEALER — Technician is the authenticated user model (no separate User table).
model Technician {
  id             String        @id @default(cuid())
  email          String        @unique
  /** Nullable for owner accounts — partial unique index in DB (WHERE d7Number IS NOT NULL). */
  d7Number       String?       @unique
  /** APEX NATIONAL PLATFORM — multi-brand username (brand.firstname.lastname); lowercase at rest. */
  apexUsername   String?       @unique
  name           String
  passwordHash   String
  /** Phase 4 Clerk — linked Clerk user id; null for legacy D7-only accounts. */
  clerkUserId    String?       @unique @map("clerk_user_id")
  /** Phase 4 — identity provider: legacy (JWT) or clerk. */
  authProvider   String        @default("legacy") @map("auth_provider")
  role           TechnicianRole @default(technician)
  isAdmin        Boolean       @default(false)
  isActive       Boolean       @default(true)
  sessionVersion Int           @default(0)
  dealerId       String?       @map("dealer_id")
  dealer         Dealer?       @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId   String
  dealership     Dealership    @relation(fields: [dealershipId], references: [id])
  /** Links service_advisor role logins to their ServiceAdvisor profile for RO scoping. */
  serviceAdvisorId String?
  serviceAdvisor   ServiceAdvisor? @relation(fields: [serviceAdvisorId], references: [id], onDelete: SetNull)
  consentAt      DateTime?
  consentVersion String?
  legalDisclaimerAt      DateTime?
  legalDisclaimerVersion String?
  firstAppLaunchAt       DateTime?
  firstAppLaunchSessionId String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  repairOrders         RepairOrder[]
  auditLogs            AuditLog[]
  usageLogs            UsageLog[]
  technicianActivityLogs TechnicianActivityLog[]
  certifiedStories       TechnicianCertifiedStory[]
  sessionRefreshTokens SessionRefreshToken[]
  dealershipMemberships TechnicianDealership[]

  @@index([dealerId])
  @@index([dealershipId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([serviceAdvisorId])
  @@index([apexUsername])
}

/** APEX Phase 5.2 — multi-rooftop membership; source of truth for dealership access scoping. */
model TechnicianDealership {
  id           String         @id @default(cuid())
  technicianId String
  technician   Technician     @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  dealershipId String
  dealership   Dealership     @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  role         TechnicianRole
  isPrimary    Boolean        @default(false)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())

  @@unique([technicianId, dealershipId])
  @@index([technicianId])
  @@index([dealershipId])
  @@index([technicianId, isActive])
}

model RepairOrder {
  id                         String       @id @default(cuid())
  /** Encrypted RO number — sole source of truth at rest. */
  roNumberEncrypted          String       @default("")
  /** HMAC blind-index tokens for RO search without decrypting roNumberEncrypted. */
  roNumberSearchTokens       String[]     @default([])
  technicianId               String
  technician                 Technician   @relation(fields: [technicianId], references: [id])
  dealerId                   String?      @map("dealer_id")
  dealer                     Dealer?      @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId               String
  dealership                 Dealership   @relation(fields: [dealershipId], references: [id])
  serviceAdvisorId           String?
  serviceAdvisor             ServiceAdvisor? @relation(fields: [serviceAdvisorId], references: [id], onDelete: SetNull)
  serviceAdvisorNameEncrypted String      @default("")
  advisorMatchConfidence     Float?
  advisorIdentifiedAt        DateTime?
  vinEncrypted               String       @default("")
  year                       String       @default("")
  make                       String       @default("")
  model                      String       @default("")
  engine                     String       @default("")
  mileageIn                  String       @default("")
  mileageOut                 String       @default("")
  customerNameEncrypted      String       @default("")
  complaintsEncrypted        String       @default("[]")
  xentryOcrTextsEncrypted    String       @default("")
  xentryImageUrls            String       @default("[]")
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  repairLines                RepairLine[]
  advisorObservations        AdvisorComplaintObservation[]

  @@index([technicianId])
  @@index([dealerId])
  @@index([dealershipId])
  @@index([roNumberSearchTokens], type: Gin)
  @@index([serviceAdvisorId])
  @@index([dealerId, dealershipId])
  /** RLS prep — composite tenant + recency for national platform list queries. */
  @@index([dealershipId, dealerId, updatedAt])
}

// ─── Advisor Intelligence (Phase 1) ─────────────────────────────────────────

model ServiceAdvisor {
  id              String   @id @default(cuid())
  dealerId        String?  @map("dealer_id")
  dealer          Dealer?  @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId    String
  dealership      Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  /** Encrypted advisor display name — sole source of truth at rest. */
  displayNameEncrypted String @default("")
  nameFingerprint String
  advisorCode     String?
  status          String   @default("active")
  mergedIntoId    String?
  /** Soft delete — historical ROs, observations, and audit data are preserved. */
  deletedAt       DateTime?
  /** Optional dealership CSI score when survey data is available. */
  csiScore        Float?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  roCount         Int      @default(0)
  aliases         ServiceAdvisorAlias[]
  observations    AdvisorComplaintObservation[]
  profile         AdvisorWritingProfile?
  repairOrders    RepairOrder[]
  linkedAccounts  Technician[]

  @@unique([dealershipId, nameFingerprint])
  @@index([dealerId])
  @@index([dealershipId, lastSeenAt])
  @@index([dealershipId, status])
  /** RLS prep — composite tenant + status for advisor scoping. */
  @@index([dealershipId, dealerId, status])
  @@index([dealershipId, deletedAt])
}

model ServiceAdvisorAlias {
  id               String         @id @default(cuid())
  serviceAdvisorId String
  serviceAdvisor   ServiceAdvisor @relation(fields: [serviceAdvisorId], references: [id], onDelete: Cascade)
  aliasText        String
  aliasFingerprint String
  hitCount         Int            @default(1)
  lastSeenAt       DateTime       @default(now())

  @@unique([serviceAdvisorId, aliasFingerprint])
  @@index([aliasFingerprint])
}

model AdvisorComplaintObservation {
  id                     String         @id @default(cuid())
  dealerId               String?        @map("dealer_id")
  dealer                 Dealer?        @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId           String
  dealership             Dealership     @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  serviceAdvisorId       String
  serviceAdvisor         ServiceAdvisor @relation(fields: [serviceAdvisorId], references: [id], onDelete: Cascade)
  repairOrderId          String
  repairOrder            RepairOrder    @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineLabel              String?
  complaintTextEncrypted String
  extractionSource       String
  extractionConfidence   Float?
  wasCorrected           Boolean        @default(false)
  vehicleMake            String?
  vehicleModel           String?
  vehicleFamily          String?
  observedAt             DateTime       @default(now())

  @@index([serviceAdvisorId, observedAt])
  @@index([repairOrderId])
  @@index([dealerId])
  @@index([dealershipId, observedAt])
}

model AdvisorWritingProfile {
  id               String         @id @default(cuid())
  serviceAdvisorId String         @unique
  serviceAdvisor   ServiceAdvisor @relation(fields: [serviceAdvisorId], references: [id], onDelete: Cascade)
  profileVersion   Int            @default(1)
  /** Encrypted advisor writing-profile JSON — may contain complaint phrasing samples. */
  profileDataEncrypted String     @default("{}")
  observationCount Int            @default(0)
  lastComputedAt   DateTime?
  updatedAt        DateTime       @updatedAt
}

model RepairLine {
  id                        String      @id @default(cuid())
  repairOrderId             String
  repairOrder               RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  dealerId                  String?     @map("dealer_id")
  dealer                    Dealer?     @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  lineNumber                Int
  /** Encrypted line description — sole source of truth at rest. */
  descriptionEncrypted      String      @default("")
  customerConcernEncrypted  String      @default("")
  technicianNotesEncrypted  String      @default("")
  xentryImageUrls           String      @default("[]")
  xentryOcrTextsEncrypted   String      @default("")
  extractedDataEncrypted    String      @default("{}")
  warrantyStoryEncrypted    String?
  /** Encrypted JSON: last MI audit/review score + coaching payload for this line. */
  storyQualityAuditEncrypted String     @default("")
  /** True when story came from a Customer Pay template — skips AI generation and quality audit. */
  isCustomerPay             Boolean     @default(false)
  /** Advisor-captured sold metrics — used for dealership KPI dashboards. */
  soldLaborHours            Float?
  soldLaborAmount           Float?
  soldPartsAmount           Float?
  customerApproved          Boolean?
  isAddOn                   Boolean?
  soldMetricsUpdatedAt      DateTime?
  /** Technician certification — binds signed story hash to persisted warranty text. */
  storyCertifiedAt              DateTime?
  storyCertifiedByTechnicianId  String?
  storyCertifiedByNameEncrypted String      @default("")
  storyCertifiedHash            String      @default("")
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  @@index([repairOrderId])
  @@index([dealerId])
  @@index([storyCertifiedAt])
}

model Template {
  id           String    @id @default(cuid())
  title        String
  category     String
  contentEncrypted String @db.Text
  /** Customer Pay templates bypass Merlin AI — instant pre-written stories. */
  isCustomerPay Boolean  @default(false)
  templateType  String   @default("Warranty")
  description   String?
  source       String    @default("seed")
  dealerId     String?   @map("dealer_id")
  dealer       Dealer?   @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId String    @default("__global__")
  createdById  String?
  useCount     Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([dealershipId, title])
  @@index([category])
  @@index([dealerId])
  @@index([dealershipId, lastUsedAt])
  @@index([source])
}

model KnowledgeBase {
  id               String   @id @default(cuid())
  title            String
  category         String
  generatedTextEncrypted    String? @db.Text
  fullOriginalTextEncrypted String  @db.Text
  cleanTemplateEncrypted    String  @db.Text
  tags             String   @default("[]")
  source           String   @default("seed")
  dealerId         String?  @map("dealer_id")
  dealer           Dealer?  @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId     String   @default("__global__")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([dealershipId, title])
  @@index([category])
  @@index([dealerId])
  @@index([dealershipId])
  @@index([source])
}

model AuditLog {
  id           String      @id @default(cuid())
  action       String
  entityType   String?
  entityId     String?
  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  dealerId     String?     @map("dealer_id")
  dealer       Dealer?     @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id])
  metadata       String      @default("{}")
  ipAddress      String?
  /** Merlin prompt version for AI story events; legacy for pre-migration rows; n/a for non-AI actions. */
  promptVersion  String      @default("legacy")
  previousHash   String      @default("GENESIS")
  entryHash      String      @default("")
  /** APEX Phase 5 — identity provider for this event: legacy | clerk | refresh. */
  authSource     String?     @map("auth_source")
  /** APEX Phase 5 — session scope at time of event: national | dealership. */
  scopeMode      String?     @map("scope_mode")
  createdAt      DateTime    @default(now())

  @@index([dealerId])
  @@index([dealershipId])
  @@index([technicianId])
  @@index([action])
  @@index([createdAt])
  @@index([dealershipId, createdAt])
  @@index([dealerId, createdAt])
  @@index([dealershipId, dealerId, action, createdAt])
}

/** APEX Phase 5 — rotating refresh tokens for fortress session model (apex PLATFORM_MODE). */
model SessionRefreshToken {
  id            String     @id @default(cuid())
  technicianId  String
  technician    Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  tokenHash     String     @unique
  familyId      String
  ipHash        String?
  userAgentHash String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime   @default(now())

  @@index([technicianId])
  @@index([familyId])
  @@index([expiresAt])
}

/** Operational technician activity — isolated from compliance AuditLog and advisor intelligence. */
/** Certified warranty story indexed per technician — separate from audit/advisor data. */
model TechnicianCertifiedStory {
  id              String     @id @default(cuid())
  dealerId        String?    @map("dealer_id")
  dealer          Dealer?    @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId    String
  technicianId    String
  technician      Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  repairOrderId   String
  repairLineId    String
  roNumber        String
  lineNumber      Int
  certifiedAt     DateTime
  certifiedByName String
  promptVersion   String     @default("legacy")
  auditLogId      String?
  createdAt       DateTime   @default(now())

  @@index([technicianId, certifiedAt(sort: Desc)])
  @@index([dealerId])
  @@index([dealershipId, certifiedAt(sort: Desc)])
  @@index([repairOrderId])
  @@index([repairLineId])
}

model TechnicianActivityLog {
  id              String   @id @default(cuid())
  dealerId        String?  @map("dealer_id")
  dealer          Dealer?  @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId    String
  technicianId    String
  technician      Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  category        String
  event           String
  message         String
  repairOrderId   String?
  repairLineId    String?
  clientSessionId String?
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())

  @@index([technicianId, createdAt])
  @@index([dealerId])
  @@index([dealershipId, category, createdAt])
  @@index([repairLineId, createdAt])
  @@index([clientSessionId, createdAt])
}

model UsageLog {
  id           String      @id @default(cuid())
  technicianId String
  technician   Technician  @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  dealerId     String?     @map("dealer_id")
  dealer       Dealer?     @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  routeKey     String
  createdAt    DateTime    @default(now())

  @@index([technicianId, createdAt])
  @@index([dealerId])
  @@index([dealershipId, createdAt])
}