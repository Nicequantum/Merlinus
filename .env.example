# PostgreSQL (Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/benz_tech?sslmode=require"

# Session signing secret (generate: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-long-random-string"

# AES-256 key for customer PII at rest (generate: openssl rand -hex 32)
ENCRYPTION_KEY="change-me-to-64-hex-characters-for-aes-256-encryption-key-here"

# xAI Grok API key — SERVER ONLY (never prefix with NEXT_PUBLIC_)
# Do not set NEXT_PUBLIC_GROK_API_KEY or NEXT_PUBLIC_XAI_API_KEY in Vercel/frontend env.
GROK_API_KEY="xai-your-key-here"

# Vercel Blob storage for diagnostic images (private access)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Vercel KV / Upstash Redis for serverless rate limiting
KV_REST_API_URL="https://your-kv-instance.upstash.io"
KV_REST_API_TOKEN="your-kv-rest-token"

# App URL (for cookies in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Live health probe for pre-rollout validation (optional — production deployment URL)
# MERLIN_BASE_URL="https://merlin.your-dealership.example"

# Server log verbosity: debug | info | warn | error (production default: info)
# LOG_LEVEL="info"

# Dealership branding (PDF headers, UI — set per deployment)
DEALERSHIP_DISPLAY_NAME="Mercedes-Benz of [City]"
DEALERSHIP_CODE="[DEALER_CODE]"

# Maintenance mode — blocks AI routes and shows banner (true | 1 | yes)
# MERLIN_MAINTENANCE_MODE="false"

# Build metadata (set automatically by scripts/validate-env.mjs and Vercel)
# NEXT_PUBLIC_BUILD_COMMIT=""
# NEXT_PUBLIC_BUILD_DATE=""

# Seed D7 identifiers (optional — defaults D7HARRIH / D7TECH001)
# ADMIN_SEED_D7="D7HARRIH"
# TECH_SEED_D7="D7TECH001"

# Seed account emails (optional — legacy migration only)
ADMIN_SEED_EMAIL="admin@dealership.com"
TECH_SEED_EMAIL="tech@dealership.com"

# Seed passwords — required for npm run db:seed (never commit the real values)
ADMIN_SEED_PASSWORD="your-secure-manager-password-here"
TECH_SEED_PASSWORD="your-secure-technician-password-here"

# Usage monitoring (M28/M29)
DAILY_USAGE_LIMIT="50"
USAGE_TIMEZONE="America/New_York"

# Voice input (M18/M19) — listening timeout in ms (default 45000)
# VOICE_LISTENING_TIMEOUT_MS="45000"
# VOICE_INPUT_LANGUAGE="en-US"

# Re-encryption batch size (M26)
# REENCRYPT_BATCH_SIZE="100"

# Trusted proxy hops for rate-limit IP (M14) — Vercel default 1
# TRUSTED_PROXY_HOPS="1"
